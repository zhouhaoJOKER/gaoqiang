# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（开发环境通常为代理前缀，如 /api ）
VITE_API_URL=/api/v1

# 在线预购（对应后端 PREORDER_API_TOKEN，/api/v2/mat/*）
VITE_PREORDER_API_BASE=/api/v2
VITE_PREORDER_API_TOKEN=dev-preorder-token-change-me

# 本地开发代理的目标后端地址（仅开发环境生效，用于解决跨域）
VITE_API_PROXY_URL=http://127.0.0.1:3100

# Delete console
VITE_DROP_CONSOLE = false