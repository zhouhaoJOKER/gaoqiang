module Api
  module V1
    class <%= controller_class_name_for_template %> < BaseController
      before_action :set_<%= singular_name %>, only: [:show, :update, :destroy]
      before_action :check_authorize

      # GET /api/v1/<%= module_path.present? ? "#{module_path}/" : "" %><%= plural_name %>
      def index
        gen_log(@current_user.id, @current_ip, params[:action], 1, "访问<%= human_name %>列表")
        
        # 基础查询
        query = <%= model_class_name_with_root %>.order("id desc")
        
        # 尝试包含关联（如果存在）
        begin
          associations = [:company, :parent, :children]
          # 只包含存在的关联
          associations.select! { |assoc| <%= model_class_name_with_root %>.reflections.key?(assoc) }
          query = query.includes(*associations) unless associations.empty?
        rescue
          # 如果关联不存在，继续执行
        end
        
        # 搜索功能
        @q = query.ransack(params[:q])
        @<%= plural_name %> = @q.result()
        
        if params[:list]
          # 列表模式，只返回顶层数据
          @<%= plural_name %> = @<%= plural_name %>.where(parent_id: nil) if <%= model_class_name_with_root %>.column_names.include?("parent_id")
          render json: {
            code: 200, 
            success: 1, 
            msg: "ok", 
            data: @<%= plural_name %>.map { |e| model_has_base_info?(e) ? e.base_info : e.attributes }, 
            total: @<%= plural_name %>.size, 
            size: per_page, 
            page: page 
          }
        else
          # 分页模式
          page_num = params[:page] || params[:current] || 1
          per_page_num = params[:per_page] || params[:size] || per_page
          @<%= plural_name %> = @<%= plural_name %>.paginate(page: page_num, per_page: per_page_num)
          render json: {
            code: 200, 
            success: 1, 
            msg: "ok", 
            data: @<%= plural_name %>.map { |e| model_has_base_info?(e) ? e.base_info : e.attributes }, 
            total: @q.result().size, 
            size: per_page_num, 
            page: page_num 
          }
        end
      end

      # GET /api/v1/<%= plural_name %>/1
      def show
        render json: {
          code: 200, 
          success: 1, 
          msg: "ok", 
          data: model_has_base_info?(@<%= singular_name %>) ? @<%= singular_name %>.base_info : @<%= singular_name %>.attributes 
        }
      end

      # POST /api/v1/<%= plural_name %>
      def create
        # 处理parent_id参数
        if params["parent_id"].present? && <%= model_class_name_with_root %>.column_names.include?("parent_id")
          <%= singular_name %>_params[:parent_id] = params["parent_id"] == 0 ? nil : params["parent_id"]
        end
        
        @<%= singular_name %> = <%= model_class_name_with_root %>.new(<%= singular_name %>_params)

        if @<%= singular_name %>.save
          # 处理父子关系（如果存在）
          if params["parent_id"].present? && <%= model_class_name_with_root %>.column_names.include?("parent_id") && params["parent_id"] != 0
            @<%= singular_name %>.update_columns(parent_id: params["parent_id"])
          end
          
          gen_log(@current_user.id, @current_ip, params[:action], 1, "添加<%= human_name %>#{@<%= singular_name %>.name rescue @<%= singular_name %>.id}成功")
          render json: {
            code: 200, 
            success: 1, 
            msg: t('create_success'), 
            data: model_has_base_info?(@<%= singular_name %>) ? @<%= singular_name %>.base_info : @<%= singular_name %>.attributes 
          }
        else
          gen_log(@current_user.id, @current_ip, params[:action], 0, "添加<%= human_name %>失败: #{@<%= singular_name %>.errors.full_messages.join(",")}")
          render json: {
            code: 500, 
            success: 0, 
            msg: @<%= singular_name %>.errors.full_messages.join(","), 
            data: "" 
          }
        end
      end

      # PATCH/PUT /api/v1/<%= plural_name %>/1
      def update
        if @<%= singular_name %>.update(<%= singular_name %>_params)
          # 处理父子关系（如果存在）
          if params["parent_id"].present? && <%= model_class_name_with_root %>.column_names.include?("parent_id")
            @<%= singular_name %>.update_columns(parent_id: params["parent_id"])
          end
          
          render json: {
            code: 200, 
            success: 1, 
            msg: "ok", 
            data: model_has_base_info?(@<%= singular_name %>) ? @<%= singular_name %>.base_info : @<%= singular_name %>.attributes 
          }
          gen_log(@current_user.id, @current_ip, params[:action], 1, "<%= human_name %>修改#{@<%= singular_name %>.name rescue @<%= singular_name %>.id} 成功")
        else
          gen_log(@current_user.id, @current_ip, params[:action], 0, "<%= human_name %>修改#{@<%= singular_name %>.name rescue @<%= singular_name %>.id} 失败: #{@<%= singular_name %>.errors.full_messages.join(",")}")
          render json: {
            code: 500, 
            success: 0, 
            msg: @<%= singular_name %>.errors.full_messages.join(","), 
            data: "" 
          }
        end
      end

      # DELETE /api/v1/<%= plural_name %>/1
      def destroy
        gen_log(@current_user.id, @current_ip, params[:action], 1, "<%= human_name %>删除#{@<%= singular_name %>.name rescue @<%= singular_name %>.id}成功")
        @<%= singular_name %>.destroy
        render json: { code: 200, success: 1, msg: "success", data: "" }
      end

      # GET /api/v1/<%= singular_name %>_trees
      def <%= singular_name %>_trees
        gen_log(@current_user.id, @current_ip, params[:action], 1, "访问<%= human_name %>树状列表")
        
        # 基础查询
        query = <%= model_class_name_with_root %>.order("id desc")
        
        # 仅返回顶层数据
        query = query.where(parent_id: nil) if <%= model_class_name_with_root %>.column_names.include?("parent_id")
        
        # 尝试包含关联（如果存在）
        begin
          associations = [:company, :parent, :children]
          # 只包含存在的关联
          associations.select! { |assoc| <%= model_class_name_with_root %>.reflections.key?(assoc) }
          query = query.includes(*associations) unless associations.empty?
        rescue
          # 如果关联不存在，继续执行
        end
        
        # 搜索和分页
        @q = query.ransack(params[:q])
        @<%= plural_name %> = @q.result().paginate(page: params[:page], per_page: per_page)
        
        # 渲染结果
        render json: {
          code: 200, 
          success: 1, 
          msg: "ok", 
          data: @<%= plural_name %>.map { |e| model_has_tree_info?(e) ? e.tree_info : (model_has_base_info?(e) ? e.base_info : e.attributes) }, 
          meta: { 
            total: @<%= plural_name %>.total_entries, 
            per_page: per_page, 
            page: page 
          } 
        }
      end

      # 导入功能
      # post api/v1/<%= plural_name %>/import
      def import
        if params[:tag] == "import_template"
          column_names = <%= model_class_name_with_root %>.respond_to?(:imp_exp_hander) ? <%= model_class_name_with_root %>.imp_exp_hander : <%= model_class_name_with_root %>.column_names
          i18n_column_names = <%= model_class_name_with_root %>.respond_to?(:il8n_imp_exp_hander) ? <%= model_class_name_with_root %>.il8n_imp_exp_hander : column_names
          data = []
          if params[:file_ext] == "csv"
            file = gen_export_csv_file(data, column_names, i18n_column_names)
          else
            file = gen_export_xlsx_file(data, column_names, i18n_column_names)
          end
          url = file.split("public/")[1]
          gen_log(@current_user.id, @current_ip, "download_template", 1, "下载导入<%= human_name %>模板成功")
          render json: { code: 200, success: 1, msg: "success", url: url }
        elsif params[:tag] == "file"
         attachment = Attachment.create(
          file: params[:file],
          user_id: @current_user.id,
          name: "导入<%= model_class_name_with_root %>.table_name",
          )
          file = attachment.file.path

          csv_data = CSV.read(file, skip_blanks: true)
          @il8n_headers = csv_data[0]
          @headers = headers = csv_data[1]
          data = csv_data[2..-1].map { |row| Hash[*headers.zip(row).flatten] }
          @csv_data = data

          gen_log(@current_user.id, @current_ip, "import_preview", 1, "导入<%= human_name %>预览数据成功")
          render json: { code: 200, success: 1, msg: "success", data: @csv_data }
        end
      end

      # 批量操作
      # post api/v1/<%= plural_name %>/batch_action
      def batch_action
        return render json: { code: 500, success: 0, msg: "请指定操作类型(actions)", data: "" } if params[:actions].blank?

        action = params[:actions]
        valid_actions = [ "create", "update", "delete" ]
        return render json: { code: 500, success: 0, msg: "无效的操作类型，支持的操作类型为：#{valid_actions.join(", ")}", data: "" } unless valid_actions.include?(action)
        data = []
        results = {
          success: 0,
          failed: 0,
          errors: []
        }
        case action
        when "create"
          return render json: { code: 500, success: 0, msg: "请求参数不能为空", data: "" } if params[:<%= plural_name %>].blank?

          <%= model_class_name_with_root %>.transaction do
            params[:<%= plural_name %>].each do |<%= singular_name %>_params|
              <%= singular_name %> = <%= model_class_name_with_root %>.new(<%= singular_name %>_params.to_unsafe_h)
              if <%= singular_name %>.save
                <%= singular_name %>.update_columns(parent_id: <%= singular_name %>_params[:parent_id]) if <%= singular_name %>_params[:parent_id].present? && <%= model_class_name_with_root %>.column_names.include?("parent_id")
                results[:success] += 1
                data << <%= singular_name %>
                gen_log(@current_user.id, @current_ip, "batch_create", 1, "批量新增<%= human_name %>#{<%= singular_name %>.name rescue <%= singular_name %>.id}成功")

              else
                results[:failed] += 1
                results[:errors] << { params: <%= singular_name %>_params, errors: <%= singular_name %>.errors.full_messages }
                gen_log(@current_user.id, @current_ip, "batch_create", 0, "批量新增<%= human_name %>#{<%= singular_name %>_params[:name]}失败: #{<%= singular_name %>.errors.full_messages.join(",")}")
              end
            end
          end

        when "update"
          return render json: { code: 500, success: 0, msg: "请求参数不能为空", data: "" } if params[:ids].blank? || params[:fields].blank? || params[:values].blank?

          selected_ids = params[:ids]
          fields = params[:fields]
          values = params[:values]

          # 过滤出需要更新的字段和值
          update_params = {}
          fields.each do |field|
            update_params[field.to_sym] = values[field] if values.key?(field)
          end

          return render json: { code: 500, success: 0, msg: "没有需要更新的字段", data: [], results: results } if update_params.empty?

          <%= model_class_name_with_root %>.transaction do
            selected_ids.each do |<%= singular_name %>_id|
              <%= singular_name %> = <%= model_class_name_with_root %>.find_by(id: <%= singular_name %>_id)
              if <%= singular_name %>
                if <%= singular_name %>.update(update_params)
                  # 处理parent_id更新（如果需要）
                  <%= singular_name %>.update_columns(parent_id: update_params[:parent_id]) if update_params[:parent_id].present? && <%= model_class_name_with_root %>.column_names.include?("parent_id")
                  results[:success] += 1
                  data << <%= singular_name %>
                  gen_log(@current_user.id, @current_ip, "batch_update", 1, "批量修改<%= human_name %>#{<%= singular_name %>.name rescue <%= singular_name %>.id}成功")
                else
                  results[:failed] += 1
                  results[:errors] << { id: <%= singular_name %>_id, errors: <%= singular_name %>.errors.full_messages }
                  gen_log(@current_user.id, @current_ip, "batch_update", 0, "批量修改<%= human_name %>#{<%= singular_name %>.name rescue <%= singular_name %>.id}失败: #{<%= singular_name %>.errors.full_messages.join(",")}")
                end
              else
                results[:failed] += 1
                results[:errors] << { id: <%= singular_name %>_id, errors: [ "记录不存在" ] }
                gen_log(@current_user.id, @current_ip, "batch_update", 0, "批量修改<%= human_name %>失败: 记录ID #{<%= singular_name %>_id} 不存在")
              end
            end
          end

        when "delete"
          <%= model_class_name_with_root %>.transaction do
            params[:ids].each do |<%= singular_name %>_id|
              <%= singular_name %> = <%= model_class_name_with_root %>.find(<%= singular_name %>_id)
              if <%= singular_name %>
                <%= singular_name %>.destroy
                results[:success] += 1
                gen_log(@current_user.id, @current_ip, "batch_delete", 1, "批量删除<%= human_name %>#{<%= singular_name %>.name rescue <%= singular_name %>.id}成功")
              else
                results[:failed] += 1
                results[:errors] << { id: <%= singular_name %>_id, errors: [ "记录不存在" ] }
                gen_log(@current_user.id, @current_ip, "batch_delete", 0, "批量删除<%= human_name %>失败: 记录ID #{<%= singular_name %>_id} 不存在")
              end
            end
          end
        end

        render json: {
          code: 200,
          success: 1,
          msg: "批量#{action}操作完成, 成功#{results[:success]}条, 失败#{results[:failed]}条",
          data: data,
          results: results
        }
      end

      private
        def set_<%= singular_name %>
          @<%= singular_name %> = <%= model_class_name_with_root %>.find(params[:id]) rescue nil
          if @<%= singular_name %>.nil?
            msg = "记录不存在！"
            gen_log(@current_user.id, @current_ip, params[:action], 0, "ID:#{params[:id]}, "+msg)
            render json: { code: 500, success: 0, msg: msg, data: params[:action] }
          end
        end

        def <%= singular_name %>_params
          params.permit(<%= permitted_params %>)
        end
        
        # 辅助方法：检查模型是否有base_info方法
        def model_has_base_info?(model)
          model.respond_to?(:base_info)
        end
        
        # 辅助方法：检查模型是否有tree_info方法
        def model_has_tree_info?(model)
          model.respond_to?(:tree_info)
        end
        
        # 权限校验方法
        def check_authorize
          begin
            authorize!(params[:action].to_sym, @<%= singular_name %> || <%= model_class_name_with_root %>)
          rescue CanCan::AccessDenied
            render json: { code: 403, success: 0, msg: "没有权限访问", data: "" }, status: :forbidden
          end
        end
    end
  end
end
