</tr>

<tr>
  <td class="content">
    <p>

      或复制以下地址到浏览器上访问 <br>
      Or copy the following address to the browser.
    </p>
    <span class="text-info">
      <%= confirmation_url(@resource, confirmation_token: @token) %>
    </span>
  </td>
</tr>

