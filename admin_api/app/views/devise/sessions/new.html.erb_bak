            </a></div>
        </div>
      </div>
    </form>


    <div class="text-center text-muted mt">
      Don't have account yet? 
      <a href="<%= new_registration_path(resource_name) %>" id="register-btn" class="uppercase">Create an account</a>
    </div>
  </div>
</div>

<%= render "layouts/footer"%>
